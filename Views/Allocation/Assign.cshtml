@model AllocationViewModel

@{
    ViewData["Title"] = "Assign Girl to Room";
}

<div class="min-vh-100 d-flex align-items-center assign-bg">
    <!-- Animated background -->
    <div class="bg-animation"></div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8 col-xl-6">
                <div class="card border-0 shadow-xl animate__animated animate__fadeInUp assign-card">
                    <div class="card-header text-center py-4 bg-gradient-primary text-white border-0">
                        <h3 class="mb-1 fw-bold">
                            <i class="bi bi-person-check-fill me-3"></i>
                            Assign Girl to Room
                        </h3>
                        <p class="mb-0 opacity-85">
                            Select a girl and an available room — beds are assigned automatically.
                        </p>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        <form asp-action="Assign" method="post" id="assignForm">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                            <!-- Select Girl -->
                            <div class="mb-5 form-floating">
                                <select asp-for="UserId" class="form-select form-select-lg shadow-sm" required>
                                    <option value="">-- Choose a Girl --</option>
                                    @foreach (var user in Model.Users)
                                    {
                                        <option value="@user.Id">@user.FullName (@user.Email)</option>
                                    }
                                </select>
                                <label asp-for="UserId" class="form-label fw-bold">Select Girl</label>
                                <span asp-validation-for="UserId" class="text-danger small"></span>
                            </div>

                            <!-- Select Room -->
                            <div class="mb-5 form-floating">
                                <select asp-for="RoomId" class="form-select form-select-lg shadow-sm" required>
                                    <option value="0">-- Choose a Room with Vacant Beds --</option>
                                    @foreach (var room in Model.AvailableRooms)
                                    {
                                        var badgeClass = room.VacantBeds <= 2 ? "bg-warning text-dark" : "bg-success text-white";
                                        <option value="@room.Id">
                                            Room @room.RoomNumber — Vacant Beds: @room.VacantBeds
                                        </option>
                                    }
                                </select>
                                <label asp-for="RoomId" class="form-label fw-bold">Select Room</label>
                                <span asp-validation-for="RoomId" class="text-danger small"></span>
                                <div class="form-text text-muted small mt-1">
                                    Only rooms with available beds are shown
                                </div>
                            </div>

                            <!-- Submit & Cancel -->
                            <div class="d-grid gap-3 d-md-flex justify-content-md-end mt-5">
                                <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow" id="submitBtn">
                                    <span class="spinner-border spinner-border-sm d-none me-2" role="status" id="loadingSpinner"></span>
                                    <i class="bi bi-check-circle-fill me-2"></i> Assign Now
                                </button>

                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">
                                    <i class="bi bi-arrow-left me-2"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>

                    <!-- Footer note -->
                    <div class="card-footer bg-light text-center py-3">
                        <small class="text-muted">
                            Assignment updates are instant. Bed will be auto-selected from available ones.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .assign-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            position: relative;
            overflow: hidden;
        }

        .bg-animation {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 30% 70%, rgba(255,255,255,0.12) 0%, transparent 50%), radial-gradient(circle at 70% 30%, rgba(255,255,255,0.08) 0%, transparent 50%);
            animation: floatBg 22s infinite alternate ease-in-out;
            pointer-events: none;
        }

        @@keyframes floatBg {
            0%

        {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(50px, -50px) scale(1.1);
        }

        }

        .assign-card {
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-radius: 24px;
            border: 1px solid rgba(255,255,255,0.25);
            overflow: hidden;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }

            .assign-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 35px 70px -15px rgba(0, 0, 0, 0.4) !important;
            }

        .bg-gradient-primary {
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
        }

        .form-select:focus, .form-select:focus-visible {
            border-color: #667eea;
            box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
        }

        .btn-primary {
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            border: none;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 35px rgba(102, 126, 234, 0.5);
            }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('assignForm');
            const submitBtn = document.getElementById('submitBtn');
            const spinner = document.getElementById('loadingSpinner');

            // Show loading state on submit
            form.addEventListener('submit', function () {
                submitBtn.disabled = true;
                spinner.classList.remove('d-none');
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Assigning...';
            });
        });
    </script>
}