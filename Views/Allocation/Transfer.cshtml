@model TransferViewModel

@{
    ViewData["Title"] = "Transfer Girl to New Room";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-gradient-primary text-white py-4">
                    <h3 class="mb-0 text-center">
                        <i class="bi bi-arrow-left-right me-3"></i>
                        Transfer Girl
                    </h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            <strong>Success!</strong> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                            <strong>Error:</strong> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="bg-light p-4 rounded mb-4 border">
                        <h5 class="text-primary mb-3">
                            <i class="bi bi-person-fill me-2"></i>
                            Girl Information
                        </h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <strong>Name:</strong> @Model.UserName
                            </div>
                            <div class="col-md-6 mb-3">
                                <strong>Current Room:</strong>
                                <span class="badge bg-info fs-6">@(Model.CurrentRoom ?? "Not Assigned")</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Transfer" method="post">
                        <input type="hidden" asp-for="UserId" />

                        <div class="mb-4">
                            <label asp-for="NewRoomId" class="form-label fw-bold fs-5">
                                <i class="bi bi-house-door-fill me-2 text-success"></i>
                                Select New Room
                            </label>

                            <select asp-for="NewRoomId" class="form-select form-select-lg shadow-sm" required>
                                <option value="0">── Choose a room with available beds ──</option>
                                @foreach (var room in Model.AvailableRooms)
                                {
                                    var badgeClass = room.VacantBeds <= 2 ? "bg-warning text-dark" : "bg-success";
                                    <option value="@room.Id">
                                        Room @room.RoomNumber
                                        — Vacant Beds: @room.VacantBeds
                                    </option>
                                }
                            </select>

                            <div class="form-text text-muted mt-2">
                                Only rooms with at least 1 vacant bed are shown.
                            </div>

                            <span asp-validation-for="NewRoomId" class="text-danger"></span>
                        </div>

                        <div class="alert alert-warning small mt-4">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            Transferring will automatically:
                            <ul class="mb-0 mt-2">
                                <li>Free the current bed</li>
                                <li>Assign a new vacant bed in the selected room</li>
                                <li>Update the girl's room record</li>
                            </ul>
                        </div>

                        <div class="d-grid gap-3 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-arrow-right-circle-fill me-2"></i>
                                Confirm Transfer
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left me-2"></i>
                                Cancel & Go Back
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-center py-3">
                    <small class="text-muted">
                        All transfers are logged. Contact Admin if you need to reverse any action.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}