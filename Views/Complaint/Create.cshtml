@model Complaint

@{
    ViewData["Title"] = "Submit Complaint";
}

<h2>Submit Maintenance Request / Complaint</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Title" class="form-label">Title</label>
        <input asp-for="Title" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="5" required></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Submit Complaint</button>
    <a asp-action="MyComplaints" class="btn btn-secondary">Cancel</a>
</form>