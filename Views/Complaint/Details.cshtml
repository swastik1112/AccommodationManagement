@model Complaint

@{
    ViewData["Title"] = "Complaint Details";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 animate__animated animate__fadeIn">
        <h2 class="fw-bold text-primary mb-0">
            <i class="bi bi-exclamation-circle-fill me-3 text-primary"></i>
            Complaint Details
        </h2>
        <a asp-action="MyComplaints" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to My Complaints
        </a>
    </div>

    <!-- Main Complaint Card -->
    <div class="card border-0 shadow-lg animate__animated animate__fadeInUp">
        <div class="card-header bg-gradient-primary text-white py-4">
            <h4 class="mb-0 fw-bold">@Model.Title</h4>
        </div>

        <div class="card-body p-4 p-md-5">
            <div class="row g-4">
                <!-- Left Column - Info -->
                <div class="col-md-6">
                    <div class="mb-4">
                        <h6 class="text-muted fw-bold mb-1">Submitted By</h6>
                        <p class="fs-5 mb-0">
                            @Model.User?.FullName
                            <small class="text-muted d-block">(@Model.User?.Email)</small>
                        </p>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-muted fw-bold mb-1">Submitted On</h6>
                        <p class="fs-5 mb-0">
                            @Model.Date.ToString("dd MMMM yyyy")
                            <small class="text-muted d-block">@Model.Date.ToString("hh:mm tt")</small>
                        </p>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-muted fw-bold mb-1">Current Status</h6>
                        <span class="badge fs-5 px-4 py-2 @(
                              Model.Status == "Pending" ? "bg-warning text-dark" :
                              Model.Status == "InProgress" ? "bg-info text-white" :
                              "bg-success text-white"
                                                )">
                            @Model.Status
                        </span>
                    </div>
                </div>

                <!-- Right Column - Description -->
                <div class="col-md-6">
                    <h6 class="text-muted fw-bold mb-2">Description</h6>
                    <div class="bg-light p-4 rounded border">
                        <p class="fs-5 mb-0 text-dark" style="white-space: pre-wrap;">
                            @Model.Description
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-light text-center py-3">
            <small class="text-muted">
                Complaint ID: #@Model.Id •
                Last updated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")
            </small>
        </div>
    </div>

    <!-- Back Button (mobile friendly) -->
    <div class="text-center mt-4 d-md-none">
        <a asp-action="MyComplaints" class="btn btn-outline-secondary btn-lg px-5">
            <i class="bi bi-arrow-left me-2"></i> Back to List
        </a>
    </div>
</div>

@section Styles {
    <style>
        .bg-gradient-primary {
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
        }

        .card {
            border-radius: 16px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
            }
    </style>
}

@section Scripts {
    <!-- Optional: Add any JS if needed (e.g., copy complaint ID, etc.) -->
    <script>
        // You can add future enhancements here
    </script>
}