@model IEnumerable<Complaint>

@{
    ViewData["Title"] = "Manage Complaints";
    var statusFilter = ViewBag.StatusFilter as string ?? "All";
    var search = ViewBag.Search as string ?? "";
    var isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3 animate__animated animate__fadeIn">
        <h2 class="fw-bold text-primary mb-0">
            <i class="bi bi-exclamation-triangle-fill me-3 text-warning"></i>
            Manage All Complaints
        </h2>

        <div class="d-flex gap-3 flex-wrap">
            <!-- Search -->
            <div class="input-group" style="min-width: 280px;">
                <input type="text" id="searchInput" class="form-control" placeholder="Search title, name or email..." value="@search">
                <button class="btn btn-outline-primary" type="button" onclick="applyFilter()">
                    <i class="bi bi-search"></i>
                </button>
            </div>

            <!-- Status Filter -->
            <select id="statusFilter" class="form-select" style="max-width: 200px;" onchange="applyFilter()">
                <option value="All" selected="@(statusFilter == "All")">All Status</option>
                <option value="Pending" selected="@(statusFilter == "Pending")">Pending</option>
                <option value="InProgress" selected="@(statusFilter == "InProgress")">In Progress</option>
                <option value="Resolved" selected="@(statusFilter == "Resolved")">Resolved</option>
            </select>
        </div>
    </div>

    <!-- Empty State -->
    @if (!Model.Any())
    {
        <div class="card border-0 shadow-lg text-center py-5 animate__animated animate__fadeIn">
            <div class="card-body">
                <i class="bi bi-check-circle-fill display-1 text-success mb-4 opacity-75"></i>
                <h4 class="text-muted mb-3">No Complaints Found</h4>
                <p class="lead text-muted mb-4">
                    @(statusFilter == "All" ? "No complaints exist yet." : $"No complaints in '{statusFilter}' status.")
                </p>
            </div>
        </div>
    }
    else
    {
        <!-- Complaints Table -->
        <div class="card border-0 shadow-lg animate__animated animate__fadeIn">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col">Sr.No.</th>
                                <th scope="col">Title</th>
                                <th scope="col">Description</th>
                                <th scope="col">Submitted By</th>
                                <th scope="col">Date</th>
                                <th scope="col">Status</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var complaint in Model)
                            {
                                var statusClass = complaint.Status switch
                                {
                                    "Pending" => "bg-warning text-dark",
                                    "InProgress" => "bg-info text-white",
                                    "Resolved" => "bg-success text-white",
                                    _ => "bg-secondary text-white"
                                };

                                <tr>
                                    <td class="text-center fw-bold">@index</td>
                                    <td class="fw-bold">@complaint.Title</td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 300px;" title="@complaint.Description">
                                            @complaint.Description
                                        </div>
                                    </td>
                                    <td>
                                        @complaint.User?.FullName
                                        <small class="text-muted d-block">(@complaint.User?.Email)</small>
                                    </td>
                                    <td>@complaint.Date.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @statusClass px-3 py-2 fs-6">
                                            @complaint.Status
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 flex-wrap justify-content-center">
                                            <!-- View Details Button -->
                                            <button class="btn btn-sm btn-info text-white view-details"
                                                    data-id="@complaint.Id"
                                                    data-title="@complaint.Title"
                                                    data-user="@(complaint.User?.FullName ?? "Unknown")"
                                                    data-email="@(complaint.User?.Email ?? "N/A")"
                                                    data-date="@complaint.Date.ToString("dd MMM yyyy HH:mm")"
                                                    data-status="@complaint.Status"
                                                    data-desc="@complaint.Description">
                                                <i class="bi bi-eye"></i> View
                                            </button>

                                            <!-- Status Change Dropdown (only if not Resolved) -->
                                            @if (complaint.Status != "Resolved")
                                            {
                                                <select class="form-select form-select-sm status-change" style="width: auto; min-width: 140px;"
                                                        data-id="@complaint.Id" data-current-status="@complaint.Status">
                                                    <option value="Pending" selected="@(complaint.Status == "Pending")">Pending</option>
                                                    <option value="InProgress" selected="@(complaint.Status == "InProgress")">In Progress</option>
                                                    <option value="Resolved" selected="@(complaint.Status == "Resolved")">Resolved</option>
                                                </select>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- View Complaint Modal -->
<div class="modal fade" id="complaintModal" tabindex="-1" aria-labelledby="complaintModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="complaintModalLabel">Complaint Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <h5 id="modalTitle" class="mb-3"></h5>
                <p><strong>Submitted by:</strong> <span id="modalUser"></span> <small id="modalEmail"></small></p>
                <p><strong>Date:</strong> <span id="modalDate"></span></p>
                <p><strong>Status:</strong> <span id="modalStatus" class="badge fs-6 px-3 py-2"></span></p>
                <hr>
                <h6>Description:</h6>
                <div class="bg-light p-4 rounded border">
                    <p id="modalDesc" class="mb-0" style="white-space: pre-wrap;"></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ────────────────────────────────────────────────
            // View Details Modal
            // ────────────────────────────────────────────────
            const viewButtons = document.querySelectorAll('.view-details');
            const modal = new bootstrap.Modal(document.getElementById('complaintModal'));

            viewButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    document.getElementById('modalTitle').textContent = this.getAttribute('data-title');
                    document.getElementById('modalUser').textContent = this.getAttribute('data-user');
                    document.getElementById('modalEmail').textContent = `(${this.getAttribute('data-email')})`;
                    document.getElementById('modalDate').textContent = this.getAttribute('data-date');

                    const statusEl = document.getElementById('modalStatus');
                    statusEl.textContent = this.getAttribute('data-status');
                    statusEl.className = `badge fs-6 px-3 py-2 ${
                        this.getAttribute('data-status') === 'Pending' ? 'bg-warning text-dark' :
                        this.getAttribute('data-status') === 'InProgress' ? 'bg-info text-white' :
                        'bg-success text-white'
                    }`;

                    document.getElementById('modalDesc').textContent = this.getAttribute('data-desc');
                    modal.show();
                });
            });

            // ────────────────────────────────────────────────
            // Status Change (AJAX - FIXED)
            // ────────────────────────────────────────────────
            const statusSelects = document.querySelectorAll('.status-change');
            statusSelects.forEach(select => {
                select.addEventListener('change', async function () {
                    const complaintId = this.getAttribute('data-id');
                    const newStatus = this.value;

                    if (!confirm(`Change status to "${newStatus}"?`)) {
                        this.value = this.getAttribute('data-current-status');
                        return;
                    }

                    const formData = new FormData();
                    formData.append('id', complaintId);
                    formData.append('newStatus', newStatus);

                    // Get anti-forgery token (must exist in layout)
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    if (token) {
                        formData.append('__RequestVerificationToken', token);
                    }

                    try {
                        const response = await fetch('/Complaint/UpdateStatus', {
                            method: 'POST',
                            body: formData,
                            credentials: 'same-origin'
                        });

                        if (!response.ok) {
                            throw new Error(`Server error: ${response.status}`);
                        }

                        const result = await response.json();

                        if (result.success) {
                            alert(result.message);
                            location.reload();
                        } else {
                            alert(result.message || 'Failed to update status.');
                            this.value = this.getAttribute('data-current-status');
                        }
                    } catch (err) {
                        alert('Error: ' + err.message);
                        this.value = this.getAttribute('data-current-status');
                    }
                });
            });

            // ────────────────────────────────────────────────
            // Filter & Search
            // ────────────────────────────────────────────────
            window.applyFilter = function () {
                const status = document.getElementById('statusFilter').value;
                const search = document.getElementById('searchInput').value.trim();
                let url = `/Complaint/Index?statusFilter=${encodeURIComponent(status)}`;
                if (search) url += `&search=${encodeURIComponent(search)}`;
                window.location.href = url;
            };
        });
    </script>
}