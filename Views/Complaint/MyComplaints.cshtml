@model IEnumerable<Complaint>

@{
    ViewData["Title"] = "My Complaints";
}

<div class="container-fluid">
    <h2 class="mb-4">My Maintenance Complaints</h2>

    <a asp-action="Create" class="btn btn-success mb-3">
        <i class="bi bi-plus-lg"></i> Submit New Complaint
    </a>

    @if (!Model.Any())
    {
        <div class="alert alert-info">You haven't submitted any complaints yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Date.ToShortDateString()</td>
                            <td>
                                <span class="badge bg-@(item.Status == "Resolved" ? "success" : "warning")">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>