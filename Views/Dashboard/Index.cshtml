<div class="row g-4">
    <!-- Quick stats -->
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 bg-gradient-primary text-white">
            <div class="card-body">
                <h6 class="text-white-75">Total Rooms</h6>
                <h3 class="mb-0">@ViewBag.TotalRooms</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 bg-gradient-success text-white">
            <div class="card-body">
                <h6 class="text-white-75">Total Girls</h6>
                <h3 class="mb-0">@ViewBag.TotalUsers</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 bg-gradient-warning text-white">
            <div class="card-body">
                <h6 class="text-white-75">Occupied Beds</h6>
                <h3 class="mb-0">@ViewBag.OccupiedBeds</h3>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm border-0 bg-gradient-info text-white">
            <div class="card-body">
                <h6 class="text-white-75">Vacant Beds</h6>
                <h3 class="mb-0">@ViewBag.VacantBeds</h3>
            </div>
        </div>
    </div>
</div>

<!-- Occupancy pie chart -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Occupancy Distribution</h5>
            </div>
            <div class="card-body">
                <canvas id="occupancyChart" height="180"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Quick actions for Admin -->
<div class="row mt-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-plus-circle display-4 text-primary mb-3"></i>
                <h5>Create New Room</h5>
                <a asp-controller="Room" asp-action="Create" class="btn btn-outline-primary">Add Room</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-person-plus display-4 text-success mb-3"></i>
                <h5>Add New User</h5>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-success">Create Account</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <i class="bi bi-arrow-left-right display-4 text-warning mb-3"></i>
                <h5>Transfer Resident</h5>
                <a asp-controller="Allocation" asp-action="Transfer" class="btn btn-outline-warning">Transfer Now</a>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4 animate__animated animate__fadeInUp">
    <div class="card-body">
        <h5>Occupancy Overview</h5>
        <canvas id="occupancyChart" height="180"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('occupancyChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Occupied', 'Vacant'],
                datasets: [{
                    data: [@ViewBag.Occupied, @ViewBag.Vacant],
                    backgroundColor: ['#ff6b6b', '#4ecdc4'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } },
                animation: { duration: 1800, easing: 'easeOutQuart' }
            }
        });
    </script>
}