@model UserDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
    var notices = ViewBag.LatestNotices as IEnumerable<Notice> ?? Enumerable.Empty<Notice>();
}

<div class="container-fluid py-4">
    <!-- Welcome Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3 animate__animated animate__fadeIn">
        <div>
            <h2 class="fw-bold text-primary mb-1">
                <i class="bi bi-person-circle me-3 text-primary"></i>
                Welcome, @Model.FullName
            </h2>
            <small class="text-muted">Your personal accommodation overview</small>
        </div>
        <small class="text-muted">Last updated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</small>
    </div>

    @if (!Model.HasRoom)
    {
        <!-- No Room Assigned -->
        <div class="card border-0 shadow-xl bg-warning-subtle text-center py-5 animate__animated animate__fadeIn">
            <div class="card-body">
                <i class="bi bi-house-slash display-1 text-warning mb-4 opacity-75"></i>
                <h4 class="text-warning mb-3">No Room Assigned Yet</h4>
                <p class="lead text-muted mb-4">
                    You haven't been allocated a room or bed. Please contact your Warden or Admin.
                </p>
                <a asp-controller="Complaint" asp-action="Create" class="btn btn-outline-warning btn-lg px-5">
                    Raise a Request
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Room & Bed Cards -->
        <div class="row g-4 mb-5">
            <div class="col-lg-6">
                <div class="card border-0 shadow-lg h-100 stat-card bg-info text-white animate__animated animate__zoomIn">
                    <div class="card-body text-center p-5">
                        <div class="icon-circle bg-white text-info mb-4 mx-auto">
                            <i class="bi bi-house-door-fill fs-1"></i>
                        </div>
                        <h5 class="mb-2 opacity-90">Your Assigned Room</h5>
                        <h1 class="display-4 fw-bold mb-0">Room @Model.RoomNumber</h1>
                        <small class="opacity-75">Your personal space</small>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-0 shadow-lg h-100 stat-card bg-success text-white animate__animated animate__zoomIn animate__delay-1s">
                    <div class="card-body text-center p-5">
                        <div class="icon-circle bg-white text-success mb-4 mx-auto">
                            <i class="bi bi-bed-fill fs-1"></i>
                        </div>
                        <h5 class="mb-2 opacity-90">Your Bed</h5>
                        <h1 class="display-4 fw-bold mb-0">Bed @Model.BedNumber</h1>
                        <small class="opacity-75">Your private spot</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Latest Notices Widget -->
        <div class="card border-0 shadow-lg mb-5 animate__animated animate__fadeIn">
            <div class="card-header bg-info text-white py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-megaphone-fill me-2"></i>
                    Latest Notices & Announcements
                </h5>
            </div>
            <div class="card-body p-0">
                @if (!notices.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-megaphone display-4 mb-3 opacity-50"></i>
                        <h5>No new notices at the moment</h5>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var notice in notices)
                        {
                            <div class="list-group-item list-group-item-action px-4 py-3">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 fw-bold @(notice.IsImportant ? "text-danger" : "")">
                                            @notice.Title
                                            @if (notice.IsImportant)
                                            {
                                                <span class="badge bg-danger ms-2">IMPORTANT</span>
                                            }
                                        </h6>
                                        <p class="mb-1 text-truncate" style="max-width: 90%;">
                                            @notice.Content
                                        </p>
                                    </div>
                                    <small class="text-muted text-nowrap ms-3">
                                        @notice.PostedDate.ToString("dd MMM HH:mm")
                                    </small>
                                </div>
                                <small class="text-muted">Posted by @notice.PostedBy</small>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-lg mb-5 animate__animated animate__fadeIn">
            <div class="card-body text-center p-4">

                <h5 class="text-danger fw-bold mb-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Emergency Assistance
                </h5>

                <p class="text-muted mb-4">
                    Use this only in case of emergency. The warden will be notified immediately.
                </p>

                <div class="d-flex justify-content-center gap-3 flex-wrap">

                    <form asp-controller="Emergency" asp-action="SendSOS" method="post">
                        <button class="btn btn-danger btn-lg px-4 shadow">
                            <i class="bi bi-bell-fill me-2"></i>
                            Send SOS Alert
                        </button>
                    </form>

                    <a href="tel:+911234567890" class="btn btn-outline-danger btn-lg px-4">
                        <i class="bi bi-telephone-fill me-2"></i>
                        Call Warden
                    </a>

                </div>

            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card border-0 shadow-lg animate__animated animate__fadeIn">
            <div class="card-header bg-light py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-lightning-charge-fill me-2 text-warning"></i>
                    Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <a asp-controller="MyRoom" asp-action="Index" class="btn btn-primary w-100 py-4 shadow-sm action-btn">
                            <i class="bi bi-door-open fs-3 mb-2 d-block"></i>
                            View Room Details & Roommates
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a asp-controller="Complaint" asp-action="MyComplaints" class="btn btn-warning w-100 py-4 shadow-sm action-btn position-relative">
                            <i class="bi bi-tools fs-3 mb-2 d-block"></i>
                            My Complaints
                            @if (Model.PendingComplaintsCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger animate__animated animate__pulse animate__infinite">
                                    @Model.PendingComplaintsCount
                                </span>
                            }
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a asp-controller="Complaint" asp-action="Create" class="btn btn-success w-100 py-4 shadow-sm action-btn">
                            <i class="bi bi-plus-circle fs-3 mb-2 d-block"></i>
                            Submit New Complaint
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        .stat-card, .card {
            transition: all 0.3s ease;
            border-radius: 20px;
            background: white;
        }

            .stat-card:hover, .card:hover {
                transform: translateY(-10px);
                box-shadow: 0 25px 50px rgba(0,0,0,0.15) !important;
            }

        .icon-circle {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .action-btn {
            transition: all 0.3s ease;
            border-radius: 16px;
            font-size: 1.15rem;
            position: relative;
            overflow: hidden;
        }

            .action-btn:hover {
                transform: scale(1.05);
                box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            }
    </style>
}