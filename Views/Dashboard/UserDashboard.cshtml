@model UserDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container-fluid py-4">
    <!-- Welcome Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 animate__animated animate__fadeIn">
        <div>
            <h2 class="fw-bold text-primary mb-1">
                <i class="bi bi-person-circle me-3 text-primary"></i>
                Welcome, @Model.FullName
            </h2>
            <small class="text-muted">Your personal accommodation overview</small>
        </div>
        <small class="text-muted">Last updated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</small>
    </div>

    @if (!Model.HasRoom)
    {
        <!-- Empty State – No Room Assigned -->
        <div class="card border-0 shadow-lg bg-warning-subtle animate__animated animate__fadeIn">
            <div class="card-body text-center py-5">
                <i class="bi bi-house-slash display-1 text-warning mb-4 opacity-75"></i>
                <h4 class="text-warning mb-3">No Room Assigned Yet</h4>
                <p class="lead text-muted mb-4">
                    You haven't been allocated a room. Please contact your Warden or Admin for assistance.
                </p>
                <a asp-controller="Complaint" asp-action="Create" class="btn btn-outline-warning btn-lg px-5">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    Raise a Request
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Room & Bed Info Cards -->
        <div class="row g-4 mb-5">
            <!-- Your Room Card -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-lg h-100 stat-card bg-info text-white animate__animated animate__zoomIn">
                    <div class="card-body text-center p-5">
                        <div class="icon-circle bg-white text-info mb-4 mx-auto">
                            <i class="bi bi-house-door-fill fs-1"></i>
                        </div>
                        <h5 class="mb-2 opacity-90">Your Assigned Room</h5>
                        <h1 class="display-4 fw-bold mb-0">Room @Model.RoomNumber</h1>
                        <small class="opacity-75">Your personal space</small>
                    </div>
                </div>
            </div>

            <!-- Your Bed Card -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-lg h-100 stat-card bg-success text-white animate__animated animate__zoomIn animate__delay-1s">
                    <div class="card-body text-center p-5">
                        <div class="icon-circle bg-white text-success mb-4 mx-auto">
                            <i class="bi bi-segmented-nav fs-1"></i>
                        </div>
                        <h5 class="mb-2 opacity-90">Your Bed</h5>
                        <h1 class="display-4 fw-bold mb-0">Bed @Model.BedNumber</h1>
                        <small class="opacity-75">Your private spot</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card border-0 shadow-lg animate__animated animate__fadeIn">
            <div class="card-header bg-light py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-lightning-charge-fill me-2 text-warning"></i>
                    Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <a asp-controller="MyRoom" asp-action="Index" class="btn btn-primary w-100 py-4 shadow-sm action-btn">
                            <i class="bi bi-door-open fs-3 mb-2 d-block"></i>
                            View Room Details & Roommates
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a asp-controller="Complaint" asp-action="MyComplaints" class="btn btn-warning w-100 py-4 shadow-sm action-btn position-relative">
                            <i class="bi bi-tools fs-3 mb-2 d-block"></i>
                            My Complaints
                            @if (Model.PendingComplaintsCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger animate__animated animate__pulse animate__infinite">
                                    @Model.PendingComplaintsCount
                                </span>
                            }
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a asp-controller="Complaint" asp-action="Create" class="btn btn-success w-100 py-4 shadow-sm action-btn">
                            <i class="bi bi-plus-circle fs-3 mb-2 d-block"></i>
                            Submit New Complaint
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        .stat-card {
            transition: all 0.3s ease;
            border-radius: 20px;
            background: white;
        }

            .stat-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 25px 50px rgba(0,0,0,0.15) !important;
            }

        .icon-circle {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .action-btn {
            transition: all 0.3s ease;
            border-radius: 16px;
            font-size: 1.15rem;
            position: relative;
            overflow: hidden;
        }

            .action-btn:hover {
                transform: scale(1.05);
                box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            }

            .action-btn::after {
                content: '';
                position: absolute;
                top: 50%;
                left: 50%;
                width: 0;
                height: 0;
                background: rgba(255,255,255,0.2);
                border-radius: 50%;
                transform: translate(-50%, -50%);
                transition: width 0.6s ease, height 0.6s ease;
                pointer-events: none;
            }

            .action-btn:active::after {
                width: 200px;
                height: 200px;
                opacity: 0;
            }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ────────────────────────────────────────────────
            // Animated Counter for Pending Complaints Badge
            // ────────────────────────────────────────────────
            const pendingBadge = document.querySelector('.pending-complaints-badge');
            if (pendingBadge) {
                const target = parseInt(pendingBadge.textContent.trim()) || 0;
                if (target > 0) {
                    let count = 0;
                    const duration = 1200; // milliseconds
                    const step = Math.ceil(target / (duration / 16));

                    const update = () => {
                        count += step;
                        if (count >= target) {
                            pendingBadge.textContent = target;
                            pendingBadge.classList.add('animate__animated', 'animate__pulse');
                        } else {
                            pendingBadge.textContent = count;
                            requestAnimationFrame(update);
                        }
                    };
                    update();
                }
            }

            // ────────────────────────────────────────────────
            // Button Ripple/Hover Animation (optional enhancement)
            // ────────────────────────────────────────────────
            const actionButtons = document.querySelectorAll('.action-btn');
            actionButtons.forEach(btn => {
                btn.addEventListener('click', function (e) {
                    const ripple = document.createElement('span');
                    const rect = btn.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;

                    ripple.classList.add('ripple-effect');
                    ripple.style.left = x + 'px';
                    ripple.style.top = y + 'px';

                    btn.appendChild(ripple);

                    setTimeout(() => {
                        ripple.remove();
                    }, 600);
                });
            });

            // ────────────────────────────────────────────────
            // Smooth scroll to top on page load (optional)
            // ────────────────────────────────────────────────
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>

    <style>
        /* Ripple effect on button click */
        .action-btn {
            position: relative;
            overflow: hidden;
        }

        .ripple-effect {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.35);
            transform: scale(0);
            animation: ripple 0.6s linear;
            pointer-events: none;
        }

        @@keyframes ripple {
            to

        {
            transform: scale(4);
            opacity: 0;
        }

        }

        /* Pulse animation for pending badge when > 0 */
        .pending-complaints-badge {
            transition: all 0.3s ease;
        }
    </style>
}