@model IEnumerable<EmergencyRequest>
@{
    ViewData["Title"] = "Command Center | SOS Alerts";
}

@section Styles {
    <style>
        .sos-card {
            border-radius: 15px;
            overflow: hidden;
        }

        .table-hover tbody tr:hover {
            background-color: rgba(220, 53, 69, 0.05);
            transition: 0.3s;
        }

        .pulse-icon {
            animation: pulse-red 2s infinite;
            border-radius: 50%;
        }

        @@keyframes pulse-red {
            0% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
            }

            70% {
                transform: scale(1);
                box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
            }

            100% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
            }
        }

        .status-badge {
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            font-weight: 700;
        }

        .btn-action {
            border-radius: 8px;
            transition: all 0.2s;
        }

            .btn-action:hover {
                transform: translateY(-1px);
            }
    </style>
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Dashboard</a></li>
                    <li class="breadcrumb-item active">Emergency</li>
                </ol>
            </nav>
            <h2 class="fw-bold m-0 d-flex align-items-center">
                <span class="pulse-icon bg-danger d-inline-block me-3" style="width: 12px; height: 12px;"></span>
                Live SOS Requests
                <span class="badge bg-soft-danger text-danger ms-3 fs-6">@Model.Count() Active</span>
            </h2>
        </div>
        <div class="text-end text-muted small">
            <i class="bi bi-clock-history me-1"></i> Last updated: @DateTime.Now.ToString("HH:mm:ss")
        </div>
    </div>

    <div class="card sos-card shadow-lg border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0 fw-bold">Active Alerts</h5>
                </div>
                <div class="col-auto">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control bg-light border-0" placeholder="Search user...">
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="bi bi-shield-check display-1 text-success opacity-25"></i>
                    </div>
                    <h4 class="text-dark fw-bold">System Status: Secure</h4>
                    <p class="text-muted">No emergency signals are currently being broadcast.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 border-0 text-uppercase small fw-bold text-muted">Requester</th>
                                <th class="border-0 text-uppercase small fw-bold text-muted">Timestamp</th>
                                <th class="border-0 text-uppercase small fw-bold text-muted">Current Status</th>
                                <th class="text-end pe-4 border-0 text-uppercase small fw-bold text-muted">Operations</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar me-3 bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-person-fill fs-5"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.UserName</div>
                                                <div class="small text-muted">ID: #@item.Id</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-dark">@item.RequestTime.ToString("HH:mm:ss")</div>
                                        <div class="small text-muted">@item.RequestTime.ToString("dd MMM yyyy")</div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-danger status-badge px-3 py-2">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Critical SOS
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a href="#" class="btn btn-sm btn-outline-primary btn-action me-2">
                                                <i class="bi bi-geo-alt-fill me-1"></i> Track
                                            </a>

                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger btn-action shadow-sm"
                                                        onclick="return confirm('Confirm resolution of this emergency?');">
                                                    <i class="bi bi-check-lg me-1"></i> Resolve
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="card-footer bg-white border-0 py-3 text-center">
            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem;">
                <i class="bi bi-info-circle me-1"></i> Encrypted end-to-end emergency channel
            </small>
        </div>
    </div>
</div>