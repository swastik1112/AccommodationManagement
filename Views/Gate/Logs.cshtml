@model IEnumerable<AccommodationManagement.Models.GateEntryLog>

@{
    ViewData["Title"] = "Gate Entry Logs";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-5 gap-3 animate__animated animate__fadeIn">
        <h2 class="fw-bold text-primary mb-0">
            <i class="bi bi-door-open-fill me-3 text-primary"></i>
            Gate Entry Logs
        </h2>
        <small class="text-muted">Real-time entry and exit records</small>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-lg text-center py-5 animate__animated animate__fadeIn">
            <div class="card-body">
                <i class="bi bi-door-closed display-1 text-muted mb-4 opacity-50"></i>
                <h4 class="text-muted mb-3">No Entry Logs Yet</h4>
                <p class="lead text-muted">No students have scanned their Digital ID at the gate yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-xl animate__animated animate__fadeIn">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col">Sr.No.</th>
                                <th scope="col">Student Name</th>
                                <th scope="col">Email</th>
                                <th scope="col">Action</th>
                                <th scope="col">Scan Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var log in Model)
                            {
                                var actionClass = log.Action.ToLower() == "entry" ? "bg-success" : "bg-danger";

                                <tr class="animate__animated animate__fadeIn">
                                    <td class="text-center fw-bold">@index</td>
                                    <td class="fw-bold">@log.User.FullName</td>
                                    <td class="text-muted">@log.User.Email</td>
                                    <td>
                                        <span class="badge @actionClass fs-6 px-4 py-2">
                                            @log.Action.ToUpper()
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@log.ScanTime.ToString("dd MMM yyyy")</strong><br>
                                        <small class="text-muted">@log.ScanTime.ToString("hh:mm tt")</small>
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Footer Summary -->
            <div class="card-footer bg-light text-center py-3">
                <small class="text-muted">
                    Showing @Model.Count() gate entries • Last updated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")
                </small>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        .table-hover tbody tr:hover {
            background-color: rgba(102, 126, 234, 0.08);
            transition: background-color 0.2s ease;
        }

        .card {
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .card:hover {
                transform: translateY(-8px);
                box-shadow: 0 25px 50px rgba(0,0,0,0.15) !important;
            }

        .badge {
            font-size: 0.95rem;
            padding: 8px 16px;
            border-radius: 50px;
        }
    </style>
}

@section Scripts {
    <script>
        // Optional: Auto-refresh every 30 seconds for live logs
        setTimeout(() => {
            window.location.reload();
        }, 30000);
    </script>
}