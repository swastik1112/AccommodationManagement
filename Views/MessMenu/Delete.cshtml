@model AccommodationManagement.Models.MessMenu

@{
    ViewData["Title"] = "Delete Mess Menu";
}

<div class="min-vh-100 d-flex align-items-center delete-bg">
    <!-- Animated background -->
    <div class="bg-animation"></div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8 col-xl-6">
                <div class="card border-0 shadow-xl animate__animated animate__fadeInUp delete-card">
                    <div class="card-header bg-danger text-white text-center py-5">
                        <div class="mx-auto mb-4" style="font-size: 3.8rem;">🗑️</div>
                        <h3 class="mb-1 fw-bold">Delete Mess Menu</h3>
                        <p class="mb-0 opacity-90">
                            This action cannot be undone
                        </p>
                    </div>

                    <div class="card-body p-5">
                        <div class="alert alert-warning border-warning">
                            <h5 class="text-danger mb-3">
                                Are you sure you want to delete this menu?
                            </h5>
                            <p class="mb-0 text-muted">
                                Date: <strong>@Model.MenuDate.ToString("dd MMMM yyyy")</strong>
                            </p>
                        </div>

                        <!-- Menu Summary -->
                        <div class="bg-light p-4 rounded border mb-5">
                            <h6 class="text-muted mb-3">Menu Details</h6>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item d-flex justify-content-between">
                                    <span class="fw-semibold">Breakfast</span>
                                    <span>@Model.Breakfast</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span class="fw-semibold">Lunch</span>
                                    <span>@Model.Lunch</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span class="fw-semibold">Dinner</span>
                                    <span>@Model.Dinner</span>
                                </li>
                                @if (!string.IsNullOrWhiteSpace(Model.SpecialNote))
                                {
                                    <li class="list-group-item">
                                        <span class="fw-semibold">Special Note:</span><br>
                                        <span class="text-muted">@Model.SpecialNote</span>
                                    </li>
                                }
                            </ul>
                        </div>

                        <form asp-action="Delete" method="post" id="deleteForm">
                            <input type="hidden" asp-for="Id" />

                            <div class="d-grid gap-3 d-md-flex justify-content-md-end">
                                <button type="submit" class="btn btn-danger btn-lg px-5 fw-bold shadow" id="submitBtn">
                                    <i class="bi bi-trash-fill me-2"></i>
                                    Yes, Delete Menu
                                </button>

                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">
                                    <i class="bi bi-arrow-left me-2"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>

                    <div class="card-footer bg-light text-center py-3">
                        <small class="text-danger fw-semibold">
                            This action is permanent and cannot be undone.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .delete-bg {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            position: relative;
            overflow: hidden;
        }

        .bg-animation {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 30% 40%, rgba(255,255,255,0.12) 0%, transparent 50%), radial-gradient(circle at 70% 70%, rgba(255,255,255,0.08) 0%, transparent 50%);
            animation: floatBg 25s infinite alternate ease-in-out;
            pointer-events: none;
        }

        @@keyframes floatBg {
            0%

        {
            transform: translate(0, 0) scale(1);
        }

        100% {
            transform: translate(50px, -50px) scale(1.1);
        }

        }

        .delete-card {
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 24px;
            border: 1px solid rgba(255,255,255,0.3);
            overflow: hidden;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }

            .delete-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 35px 70px -15px rgba(0,0,0,0.45) !important;
            }

        .bg-gradient-primary, .bg-gradient-success, .bg-gradient-warning, .bg-danger {
            background: linear-gradient(90deg, #dc3545 0%, #c82333 100%);
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('deleteForm');
            const submitBtn = document.getElementById('submitBtn');

            form.addEventListener('submit', function () {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Deleting...';
            });
        });
    </script>
}