@model Room

@{
    ViewData["Title"] = $"Edit Room {Model.RoomNumber}";
}

<div class="container mt-4">
    <h2>Edit Room @Model.RoomNumber</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-4">
            <label asp-for="RoomNumber" class="form-label fw-bold">Room Number</label>
            <input asp-for="RoomNumber" class="form-control" required />
            <span asp-validation-for="RoomNumber" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="TotalBeds" class="form-label fw-bold">Total Beds</label>
            <input asp-for="TotalBeds" class="form-control" type="number" min="1" max="20" required />
            <span asp-validation-for="TotalBeds" class="text-danger"></span>
            <small class="form-text text-muted">
                Current occupied beds: @Model.OccupiedBeds<br>
                Cannot set below current occupied count.
            </small>
        </div>

        <div class="d-grid gap-2 d-md-flex">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-save me-2"></i> Save Changes
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const deleteButtons = document.querySelectorAll('.delete-btn');
            const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
            const roomNameSpan = document.getElementById('roomToDelete');
            const deleteForm = document.getElementById('deleteForm');

            deleteButtons.forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    const roomId = this.getAttribute('data-id');
                    const roomNumber = this.getAttribute('data-room');

                    roomNameSpan.textContent = roomNumber;
                    deleteForm.action = `/Room/Delete/${roomId}`;

                    // Optional: AJAX delete with success message
                    deleteForm.addEventListener('submit', async function (ev) {
                        ev.preventDefault();
                        const response = await fetch(deleteForm.action, {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            }
                        });

                        const result = await response.json();

                        if (result.success) {
                            alert(result.message);
                            location.reload();
                        } else {
                            alert(result.message || "Failed to delete room.");
                        }

                        modal.hide();
                    });

                    modal.show();
                });
            });
        });
    </script>
}