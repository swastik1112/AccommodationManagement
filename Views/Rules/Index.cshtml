@{
    ViewData["Title"] = "Hostel Rules & Guidelines";
}

<div class="container-fluid py-4">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-list-check me-2"></i> Hostel Rules & Guidelines
        </h2>
        <p class="text-muted">Please follow these rules to maintain a safe and comfortable hostel environment.</p>
    </div>

    <div class="row g-4">

        <!-- Hostel Timings -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-primary shadow-sm h-100">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-clock-history text-primary fs-1"></i>
                        <h5 class="mt-2 fw-bold">Hostel Timings</h5>
                    </div>
                    <ul class="list-unstyled small">
                        <li class="mb-2">• Gate closes at <strong>10:00 PM</strong></li>
                        <li class="mb-2">• Students must return before closing time</li>
                        <li>• Late entry requires warden permission</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Visitor Policy -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-success shadow-sm h-100">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-people text-success fs-1"></i>
                        <h5 class="mt-2 fw-bold">Visitor Policy</h5>
                    </div>
                    <ul class="list-unstyled small">
                        <li class="mb-2">• Allowed from <strong>4:00 PM – 7:00 PM</strong></li>
                        <li class="mb-2">• Register at security desk</li>
                        <li>• Visitors not allowed inside rooms</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Mess Rules -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-warning shadow-sm h-100">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-cup-hot text-warning fs-1"></i>
                        <h5 class="mt-2 fw-bold">Mess Rules</h5>
                    </div>
                    <ul class="list-unstyled small">
                        <li class="mb-2">• Breakfast: <strong>7:30 – 9:00 AM</strong></li>
                        <li class="mb-2">• Lunch: <strong>12:30 – 2:00 PM</strong></li>
                        <li class="mb-2">• Dinner: <strong>7:30 – 9:30 PM</strong></li>
                        <li>• Maintain cleanliness</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Discipline Rules -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-danger shadow-sm h-100">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-shield-check text-danger fs-1"></i>
                        <h5 class="mt-2 fw-bold">Discipline</h5>
                    </div>
                    <ul class="list-unstyled small">
                        <li class="mb-2">• No loud music after <strong>10:30 PM</strong></li>
                        <li class="mb-2">• Keep rooms clean</li>
                        <li class="mb-2">• Report maintenance issues</li>
                        <li>• Smoking & alcohol prohibited</li>
                    </ul>
                </div>
            </div>
        </div>

    </div>

</div>
