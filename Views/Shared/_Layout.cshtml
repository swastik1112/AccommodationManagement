<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
   <!-- add data-bs-theme for dark mode support -->
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Girls RMS - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" /> <!-- animate.css for easy entrances -->
    @RenderSection("Styles", required: false)

    <style>
        :root {
            --primary: #6f42c1; /* purple main color – girls accommodation vibe */
            --primary-light: #9f7ee9;
            --sidebar-width: 260px;
            --sidebar-collapsed: 78px;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }

        .sidebar {
            width: var(--sidebar-width);
            transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            background: linear-gradient(180deg, #4e54c8 0%, #8f94fb 100%);
            color: white;
            overflow: hidden;
            position: fixed;
            height: 100vh;
            z-index: 1000;
            box-shadow: 4px 0 20px rgba(0,0,0,0.15);
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed);
            }

            .sidebar .nav-link {
                color: rgba(255,255,255,0.9);
                transition: all 0.3s ease;
                padding: 0.9rem 1.5rem;
                border-radius: 0 30px 30px 0;
                margin: 0.25rem 0;
            }

                .sidebar .nav-link:hover,
                .sidebar .nav-link.active {
                    background: rgba(255,255,255,0.18);
                    transform: translateX(8px);
                    color: white;
                    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
                }

                .sidebar .nav-link i {
                    font-size: 1.4rem;
                    min-width: 35px;
                }

        .main-content {
            margin-left: var(--sidebar-width);
            transition: margin-left 0.35s;
            padding: 1.5rem;
        }

        .sidebar.collapsed ~ .main-content {
            margin-left: var(--sidebar-collapsed);
        }

        /* Card hover lift + scale */
        .card {
            transition: all 0.3s ease;
            border: none;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        }

            .card:hover {
                transform: translateY(-8px) scale(1.02);
                box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            }

        /* Dark mode adjustments */
        [data-bs-theme="dark"] body {
            background: linear-gradient(135deg, #1e1e2f 0%, #2a2a40 100%);
        }

        [data-bs-theme="dark"] .card {
            background: #2a2a40;
            color: white;
        }

        @@media (max-width: 992px) {
            .sidebar

        {
            width: 0;
        }

        .sidebar.show {
            width: var(--sidebar-width);
        }

        .main-content {
            margin-left: 0 !important;
        }

        }
    </style>
</head>
<body>

    <div class="d-flex">
        <!-- Sidebar -->
        <!-- Sidebar -->
        <!-- Sidebar -->
        <nav class="sidebar bg-gradient-primary text-white" id="sidebar">
            <div class="d-flex align-items-center justify-content-between p-3">
                <h4 class="mb-0 fw-bold">
                    <i class="bi bi-building-fill-gear me-2"></i> Girls RMS
                </h4>
                <button class="btn btn-link text-white fs-4 d-lg-none" id="closeSidebar">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <hr class="mx-3 opacity-50" />

            <ul class="nav flex-column px-2">

                <!-- Dashboard – visible to everyone -->
                <li class="nav-item">
                    <a class="nav-link @(IsActive("Dashboard", "Index"))"
                       asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                </li>

                <!-- ──────────────────────────────────────────────── -->
                <!-- ADMIN & WARDEN – Core Management -->
                @if (User.IsInRole("Admin") || User.IsInRole("Warden"))
                {
                    <li class="nav-item mt-3">
                        <small class="px-3 text-uppercase opacity-75 fw-semibold">Accommodation</small>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Room", "Index"))"
                           asp-controller="Room" asp-action="Index">
                            <i class="bi bi-house-door-fill me-2"></i> Rooms
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Allocation", "Index"))"
                           asp-controller="Allocation" asp-action="Index">
                            <i class="bi bi-person-check-fill me-2"></i> Assign / Transfer
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Complaint", "Index"))"
                           asp-controller="Complaint" asp-action="Index">
                            <i class="bi bi-exclamation-circle-fill me-2"></i> Complaints
                        </a>
                    </li>
                }

                <!-- ──────────────────────────────────────────────── -->
                <!-- ADMIN ONLY – User & Role Management -->
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item mt-3">
                        <small class="px-3 text-uppercase opacity-75 fw-semibold">Administration</small>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Account", "Register"))"
                           asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus-fill me-2"></i> Create User / Warden
                        </a>
                    </li>

                    <!-- Optional: if you later create UsersController for listing/editing users -->
                    <!--
                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Users", "Index"))"
                           asp-controller="Users" asp-action="Index">
                            <i class="bi bi-people-fill me-2"></i> Manage Users
                        </a>
                    </li>
                    -->
                }

                <!-- ──────────────────────────────────────────────── -->
                <!-- USER (Girl Employee) ONLY -->
                @if (User.IsInRole("User"))
                {
                    <li class="nav-item mt-3">
                        <small class="px-3 text-uppercase opacity-75 fw-semibold">My Accommodation</small>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(IsActive("MyRoom", "Index"))"
                           asp-controller="MyRoom" asp-action="Index">
                            <i class="bi bi-door-open-fill me-2"></i> My Room & Bed
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(IsActive("Complaint", "MyComplaints"))"
                           asp-controller="Complaint" asp-action="MyComplaints">
                            <i class="bi bi-tools me-2"></i> My Complaints
                        </a>
                    </li>
                }

                <!-- Logout – always at bottom -->
                <li class="nav-item mt-auto">
                    <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </a>
                </li>
            </ul>
        </nav>

        @* Helper function for active link highlighting *@
        @functions {
            private string IsActive(string controller, string action = "Index")
            {
                string? currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                string? currentAction = ViewContext.RouteData.Values["Action"]?.ToString();

                if (currentController == controller && currentAction == action)
                {
                    return "active";
                }

                // Special case for Account/Register (creating users)
                if (controller == "Account" && action == "Register" && currentController == "Account")
                {
                    return "active";
                }

                return "";
            }
        }
        <!-- Main Content -->
        <div class="flex-grow-1 main-content">
            <header class="d-flex justify-content-between align-items-center mb-4">
                <button class="btn btn-primary d-lg-none" id="toggleSidebar"><i class="bi bi-list"></i></button>
                <h2 class="animate__animated animate__fadeIn">@ViewData["Title"]</h2>
                <div>
                    <!-- Dark mode toggle (optional JS below) -->
                    <button class="btn btn-outline-secondary" id="themeToggle"><i class="bi bi-moon-stars"></i></button>
                </div>
            </header>

            <main class="animate__animated animate__fadeIn animate__delay-1s">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar toggle (mobile)
        const sidebar = document.getElementById('sidebar');
        document.getElementById('toggleSidebar')?.addEventListener('click', () => sidebar.classList.add('show'));
        document.getElementById('closeSidebar')?.addEventListener('click', () => sidebar.classList.remove('show'));

        // Optional: Collapse sidebar on desktop (click header icon or long press)
        // You can add a collapse button if needed

        // Dark mode toggle
        document.getElementById('themeToggle')?.addEventListener('click', () => {
            document.documentElement.setAttribute('data-bs-theme',
                document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @Html.AntiForgeryToken()
</body>
</html>